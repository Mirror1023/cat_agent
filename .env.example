# === Required: Anthropic ===
ANTHROPIC_API_KEY=sk-ant-api

# === Required: Instagram Platform API (Instagram Login — no Facebook needed) ===
INSTAGRAM_ACCESS_TOKEN=7294
INSTAGRAM_ACCOUNT_ID=178
INSTAGRAM_APP_ID=924
INSTAGRAM_APP_SECRET=efb5

# === Required: Admin Dashboard ===
ADMIN_PASSWORD=change_me_to_something_strong
SECRET_KEY=generate_a_random_secret_key_here

# === Optional ===
OPENAI_API_KEY=sk-xxxxxxxxxxxx          # Only needed for DALL-E image generation

# === Agent Defaults (can also be changed in dashboard) ===
IMAGE_SOURCE=random                      # Options: cat_api, dalle, local, random
POST_INTERVAL_HOURS=8                    # Hours between auto-posts
ENABLE_COMMENT_REPLIES=true              # Auto-reply to comments
MAX_POSTS_PER_DAY=3                      # Safety cap
AGENT_PERSONA=You are a playful, witty cat lover who runs a fun Instagram account about cats. Use cat puns, emojis, and a warm friendly tone.
